# Frontend Environment Configuration
# ------------------------------------------------------------------
# IMPORTANT: Do NOT put Database passwords or SMTP credentials here.
# The frontend is public code. Only put the API URL here.
# ------------------------------------------------------------------

# Production: The full URL of your deployed backend
# Example: https://mintcom-backend.onrender.com
#
# Local Development: You can leave this empty (defaults to http://localhost:3000)
VITE_API_URL=https://grateful-liberation-production-d036.up.railway.app

# Public site URL used for canonical tags and social metadata
VITE_SITE_URL=https://mintcompos.com

# Google OAuth Client ID
# Get this from Google Cloud Console: https://console.cloud.google.com/
# 1. Create a new project or select existing
# 2. Go to APIs & Services > Credentials
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add authorized JavaScript origins:
#    - http://localhost:5173 (for development)
#    - http://localhost:5174 (for this repo's Vite dev server)
#    - https://mintcompos.com (for production)
#    - https://www.mintcompos.com (if you serve the www hostname)
# 5. Copy the Client ID here
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Google Analytics 4 Measurement ID.
# Get it from Google Analytics > Admin > Data streams > Web stream > Measurement ID.
# Example format: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=

# Public app-store or verified installer URLs.
# Leave blank until the production store listing or signed installer CDN is ready.
# Do not use placeholder domains in production because security scanners flag them.
VITE_ANDROID_DOWNLOAD_URL=
VITE_IOS_DOWNLOAD_URL=
